# MongoDB
MONGODB_URI=mongodb://localhost:27017/telegram-ai-bot

# App
NODE_ENV=development
PORT=3000

# Bot Metadata
BOT_NAME=Groq AI Bot
BOT_VERSION=1.0.0

# Telegram
BOT_TOKEN=your_telegram_bot_token_here
WEBHOOK_DOMAIN=https://your-domain.com
WEBHOOK_PATH=/webhook/telegram

# Groq API (OpenAI-compatible)
GROQ_API_KEY=your_groq_api_key_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# Image Generation
IMAGE_PROVIDER=huggingface
HUGGINGFACE_TOKEN=your_huggingface_token_here
HUGGINGFACE_IMAGE_MODEL=black-forest-labs/FLUX.1-schnell

# Video Generation
VIDEO_PROVIDER=falai
FAL_AI_API_KEY=your_fal_ai_api_key_here
FAL_AI_VIDEO_MODEL=fal-ai/kling-video/v1.6/standard/text-to-video

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Credits
DAILY_FREE_CREDITS=20

# CORS (comma-separated origins for production)
CORS_ORIGIN=*

# Logging
LOG_LEVEL=info

# Admin (comma-separated Telegram user IDs)
ADMIN_IDS=

# Health check secret (optional, set to require ?secret=xxx)
HEALTH_SECRET=
