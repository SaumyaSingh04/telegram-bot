{
  "name": "telegram-ai-superbot",
  "version": "1.0.0",
  "description": "Production-ready Telegram AI Super Bot with chat, image, and video generation",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "pm2:start": "pm2 start ecosystem.config.js",
    "pm2:stop": "pm2 stop telegram-ai-superbot",
    "pm2:restart": "pm2 restart telegram-ai-superbot",
    "pm2:logs": "pm2 logs telegram-ai-superbot",
    "docker:build": "docker build -t telegram-ai-superbot .",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "compression": "^1.7.4",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "groq-sdk": "^0.3.3",
    "helmet": "^7.1.0",
    "joi": "^17.13.1",
    "mongoose": "^8.4.3",
    "morgan": "^1.10.0",
    "openai": "^4.52.0",
    "telegraf": "^4.16.3",
    "uuid": "^10.0.0",
    "winston": "^3.13.0",
    "winston-daily-rotate-file": "^5.0.0"
  },
  "devDependencies": {
    "pm2": "^5.4.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
